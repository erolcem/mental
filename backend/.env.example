# Copy to .env (or set in Railway → Variables).
GEMINI_API_KEY=            # aistudio.google.com — same key type as physical's coach

# Model tiers. gemini-3.5-flash (GA, mid-2026) is the default for both:
# frontier-flash judgement at ~$1.50/$9 per M tokens — a nightly close plus a
# handful of examiner/review calls lands around $2-4/month. For maximum
# judgement on verdicts/grading/close, set GEMINI_MODEL_DEEP=gemini-3.1-pro
# (~2.5× the cost). Conversational replies always use GEMINI_MODEL.
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_DEEP=gemini-3.5-flash
GEMINI_THINKING_CHAT=low   # thinking level for replies (minimal|low|medium|high)
GEMINI_THINKING_DEEP=high  # thinking level for verdicts, grading, the close

APP_TOKEN=                 # any long random string; must match the app's --dart-define=APP_TOKEN
CORS_ORIGINS=*
SYNC_DB=                   # optional path for the Sky Link sync store, e.g. /data/mental_sync.db (empty = ./mental_sync.db)
